{
  "name": "netivo/wc-product-endpoints",
  "description": "Netivo Module for WooCommerce to add product endpoints like sales, promotions, bestsellers, etc.",
  "minimum-stability": "stable",
  "license": "proprietary",
  "version": "1.0",
  "authors": [
    {
      "name": "netivo",
      "email": "biuro@netivo.pl"
    },
    {
      "name": "Michał Świątek",
      "email": "michal.swiatek@netivo.pl"
    }
  ],
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0",
    "brain/monkey": "^2.6"
  },
  "autoload": {
    "psr-4": {
      "Netivo\\Module\\WooCommerce\\ProductEndpoints\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Netivo\\Module\\WooCommerce\\ProductEndpoints\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": [
      "@php -d zend.enable_gc=0 vendor/bin/phpunit"
    ]
  }
}
